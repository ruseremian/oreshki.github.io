# Supabase stores order requests and order items.
# On Vercel, use Production values for main and Preview values for preprod/feature branches.
# Prefer separate Supabase projects or keys for production and preprod when possible.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=

# Lightweight owner admin access.
# Use a separate preprod value in Vercel Preview variables.
ADMIN_PASSWORD=

# Manual WhatsApp shortcut for confirming orders, pickup/delivery details, and customer questions.
# Do not use for marketing messages unless the customer explicitly agrees.
ADMIN_WHATSAPP_NUMBER=

# Telegram owner notifications and protected confirm/cancel actions.
# Use separate Preview values for preprod notification testing when possible.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
